  "provider": "ollama",
  "models": [
    {
      "match": "gpt-oss",
      "priority": 1,
      "enabled": true,
      "execution": {
        "context_length": 128000,
        "max_output_tokens": 16384,
        "supports_tools": true,
        "supports_vision": false,
        "family": "ollama",
