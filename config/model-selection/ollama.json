    },
    { "match": "deepseek", "priority": 2, "enabled": true, "execution": { "timeout_seconds": 120 } },
    { "match": "qwen", "priority": 3, "enabled": true, "execution": { "timeout_seconds": 120 } },
    { "match": "mistral", "priority": 4, "enabled": true, "execution": { "timeout_seconds": 120 } },
    { "match": "llama", "priority": 5, "enabled": true, "execution": { "timeout_seconds": 120 } },
    { "match": "nemotron", "priority": 6, "enabled": true, "execution": { "timeout_seconds": 120 } },
    { "match": "kimi", "priority": 7, "enabled": true, "execution": { "timeout_seconds": 120 } }
  ]
}
