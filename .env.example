# ─── Multi-Provider AI Proxy Configuration ─────────────────────────
# Configure one or more providers.
# Supported: deepseek, google, openai, zhipu, qwen, minimax, hunyuan,
#            nvidia, openrouter, groq, ollama, moonshot, kimi, cerebras,
#            zenmux, customopenai
# Models are auto-discovered from provider catalogs (/v1/models or /api/tags for ollama).

PROVIDER_DEEPSEEK_API_KEY=sk-your-deepseek-key-here
PROVIDER_DEEPSEEK_BASE_URL=https://api.deepseek.com

# Uncomment to add more providers:
#PROVIDER_GOOGLE_API_KEY=your-google-gemini-api-key-here
# PROVIDER_GOOGLE_BASE_URL defaults to https://generativelanguage.googleapis.com
#   Gemini models with generous free tier for coding/razonamiento:
#   gemini-2.5-pro (best coding), gemini-2.5-flash (1M ctx, free grounding),
#   gemini-3.5-flash (fastest, free cache), gemini-3-flash-preview (cheap output)
#PROVIDER_OPENAI_API_KEY=sk-your-openai-key-here
#PROVIDER_OPENAI_BASE_URL=https://api.openai.com

# Zhipu / BigModel (OpenAI-compatible, e.g. glm-5.2):
#PROVIDER_ZHIPU_API_KEY=your-zhipu-bigmodel-api-key
# PROVIDER_ZHIPU_BASE_URL defaults to https://open.bigmodel.cn/api/paas

# Alibaba Qwen / DashScope compatible mode:
#PROVIDER_QWEN_API_KEY=your-dashscope-api-key
# PROVIDER_QWEN_BASE_URL defaults to https://dashscope.aliyuncs.com/compatible-mode

# MiniMax international OpenAI-compatible endpoint:
#PROVIDER_MINIMAX_API_KEY=your-minimax-api-key
# PROVIDER_MINIMAX_BASE_URL defaults to https://api.minimax.io

# Tencent Hunyuan through the current TokenHub platform:
#PROVIDER_HUNYUAN_API_KEY=your-tokenhub-api-key
# PROVIDER_HUNYUAN_BASE_URL defaults to https://tokenhub.tencentmaas.com

# Kimi China (platform.kimi.com; its keys are not shared with Moonshot international):
#PROVIDER_KIMI_API_KEY=sk-your-kimi-cn-key
# PROVIDER_KIMI_BASE_URL defaults to https://api.moonshot.cn

#PROVIDER_NVIDIA_API_KEY=nvapi-your-nvidia-key-here
#PROVIDER_NVIDIA_BASE_URL=https://integrate.api.nvidia.com
#PROVIDER_OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here
# PROVIDER_OPENROUTER_BASE_URL defaults to https://openrouter.ai/api
#PROVIDER_GROQ_API_KEY=gsk_your-groq-key-here
# PROVIDER_GROQ_BASE_URL defaults to https://api.groq.com/openai
#PROVIDER_OLLAMACLOUD_API_KEY=your-ollama-cloud-api-key
# Optional backward-compatible alias: PROVIDER_OLLAMA_API_KEY
# PROVIDER_OLLAMA_BASE_URL defaults to https://ollama.com

# Uncomment for ZenMux (multi-model aggregator with insurance mechanism):
# PROVIDER_ZENMUX_API_KEY=your-zenmux-api-key
# PROVIDER_ZENMUX_BASE_URL defaults to https://zenmux.ai/api
#   ZenMux is an enterprise-grade model aggregation platform with OpenAI-compatible API.
#   Models include glm-5.2 and other models from multiple providers.

# Generic OpenAI-compatible provider (Vercel AI Gateway example).
# This project appends /v1/models and /v1/chat/completions, so omit /v1 here.
# Create an AI Gateway API key in Vercel, then replace the placeholder below.
#PROVIDER_CUSTOMOPENAI_API_KEY=your-vercel-ai-gateway-key
#PROVIDER_CUSTOMOPENAI_BASE_URL=https://ai-gateway.vercel.sh

# Legacy format (works without PROVIDER_ prefix):
# DEEPSEEK_API_KEY=sk-your-api-key-here
# DEEPSEEK_BASE_URL=https://api.deepseek.com

DEEPSEEK_MODEL=deepseek-v4-pro
PROXY_PORT=11434
# PROXY_API_KEY=    # optional: set to require auth on the proxy itself
